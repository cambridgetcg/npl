{
  "name": "npl",
  "version": "1.1.0",
  "description": "Natural Language Protocol — the internet rewritten. Trust lives in grammar, not certificates.",
  "type": "module",
  "main": "./index.mjs",
  "bin": {
    "npl": "./npl.mjs"
  },
  "exports": {
    ".": "./index.mjs",
    "./lang": "./packages/lang/index.mjs",
    "./dns": "./packages/dns/index.mjs",
    "./tcp": "./packages/tcp/index.mjs",
    "./http": "./packages/http/index.mjs",
    "./tls": "./packages/tls/index.mjs",
    "./sync": "./packages/sync/index.mjs",
    "./identity": "./packages/identity/index.mjs"
  },
  "scripts": {
    "test": "node test.mjs",
    "start": "node npl.mjs server",
    "send": "node npl.mjs send"
  },
  "keywords": ["npl", "natural-language", "protocol", "internet", "youspeak", "trust", "grammar", "clear-standard", "p2p", "agents"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cambridgetcg/npl"
  },
  "homepage": "https://npl-ivory.vercel.app",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}